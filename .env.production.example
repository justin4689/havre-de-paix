# Modèle de .env de PRODUCTION — à copier en `.env` sur le VPS et à compléter.
# Générer APP_KEY :
#   docker compose -f docker-compose.prod.yml run --rm --no-deps app php artisan key:generate --show

APP_NAME="Résidence Hôtel Cascades"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.residencehotelcascades.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error

# Port HTTP publié par Nginx sur le VPS (TLS via Cloudflare / reverse proxy)
HTTP_PORT=80

# Migrations au démarrage du conteneur (0 = étape de déploiement manuelle)
RUN_MIGRATIONS=0

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cascades
DB_USERNAME=cascades
DB_PASSWORD=CHANGER-MOI-mot-de-passe-fort
DB_ROOT_PASSWORD=CHANGER-MOI-root-fort

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Emails transactionnels via Brevo (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=CHANGER-MOI-identifiant-brevo
MAIL_PASSWORD=CHANGER-MOI-cle-smtp-brevo
MAIL_FROM_ADDRESS="reservation@residencehotelcascades.com"
MAIL_FROM_NAME="${APP_NAME}"

# Boîte qui reçoit les alertes de réservation et messages de contact
HOTEL_EMAIL=contact@residencehotelcascades.com

VITE_APP_NAME="${APP_NAME}"
